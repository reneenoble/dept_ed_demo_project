{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Flask app",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/server.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "FLASK_ENV": "development"
      }
    },
    {
      "name": "Run tests (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "-v"
      ],
      "justMyCode": false
    },
    {
      "name": "Debug current test file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "-v",
        "${file}"
      ],
      "justMyCode": false
    }
  ]
}
