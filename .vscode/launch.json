{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Flask app",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/server.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "windows": {
        "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "env": {
        "FLASK_ENV": "development"
      }
    }
  ]
}
